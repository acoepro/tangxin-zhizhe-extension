{
  "manifest_version": 3,
  "name": "糖心志者",
  "version": "2.2.0",
  "description": "账号池管理、播放状态展示、视频下载和版本更新管理工具。",
  "permissions": [
    "storage",
    "downloads",
    "offscreen"
  ],
  "host_permissions": [
    "https://txh068.com/*",
    "https://*/*",
    "http://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://txh068.com/*"
      ],
      "js": [
        "content.js",
        "dist-ui/txzz-ui.js"
      ],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "糖心志者"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "nav_guard.js",
        "page_hook.js",
        "page_probe.js",
        "display_patch.js",
        "dist-ui/txzz-ui.css",
        "README.md",
        "update.json",
        "vendor/mux-7.0.0.min.js"
      ],
      "matches": [
        "https://txh068.com/*"
      ]
    }
  ]
}
